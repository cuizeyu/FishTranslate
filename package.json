{
  "name": "fish-translate",
  "version": "1.0.0",
  "description": "鱼语翻译桌面应用",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "clean:dist": "node scripts/clean-dist.mjs",
    "build:win": "pnpm clean:dist && electron-vite build && electron-builder --win",
    "build:mac": "pnpm clean:dist && electron-vite build && electron-builder --mac",
    "build:unpack": "pnpm clean:dist && electron-vite build && electron-builder --dir",
    "build:mac:unpack": "pnpm clean:dist && electron-vite build && electron-builder --mac --dir",
    "icon:build": "node scripts/run-python.mjs scripts/icon/convert_icon.py",
    "py:install": "node scripts/run-python.mjs -m pip install -r requirements.txt"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "antd": "^6.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-builder",
      "esbuild"
    ]
  }
}
